{
  "name": "zdc-smartgit-cli",
  "version": "1.1.1",
  "description": "AI-powered Git assistant CLI tool",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "smartgit": "dist/cli.js",
    "aigit": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/entrypoints/cli.ts",
    "build": "tsup",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "git",
    "ai",
    "cli",
    "assistant",
    "commit",
    "smart-commit"
  ],
  "author": "@jangze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jangze/smart-git.git"
  },
  "homepage": "https://github.com/jangze/smart-git#readme",
  "bugs": {
    "url": "https://github.com/jangze/smart-git/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "execa": "^9.5.2",
    "https-proxy-agent": "^9.0.0",
    "inquirer": "^11.1.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "rollup": "^4.29.1",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
